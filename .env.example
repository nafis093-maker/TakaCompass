# --- Google sign-in (works fully client-side once set) ----------------------
# Create at: https://console.cloud.google.com/apis/credentials
#   → Create credentials → OAuth client ID → Web application
#   → Authorized JavaScript origins: add your deployed URL
#     e.g. https://taka-compass.vercel.app   (and http://localhost:5173 for dev)
VITE_GOOGLE_CLIENT_ID=

# --- Apple sign-in (optional; needs an Apple Developer account + api/apple-auth.js)
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=

# Server-side (set in Vercel project env, NOT prefixed with VITE_):
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=
